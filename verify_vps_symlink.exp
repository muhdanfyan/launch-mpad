#!/usr/bin/expect -f
set timeout 60
set password "Sipanda123#"
set host "157.10.252.74"
set user "sipanda"

spawn ssh $user@$host
expect "password:"
send "$password\r"
expect "$ "

send "ls -l /etc/nginx/sites-enabled/\r"
expect "$ "

send "ls -l /etc/nginx/sites-available/launch-mpad\r"
expect "$ "

send "exit\r"
expect eof
